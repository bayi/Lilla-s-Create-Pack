  "create_dragons_plus.ponder.air_current_interact_with_block.header": "Air Currents of Bulk Processing from Simulated Contraptions",
  "create_dragons_plus.ponder.air_current_interact_with_block.text_1": "Air Current of Bulk Processing from Simulated Contraptions can affect block",
  "create_dragons_plus.ponder.air_current_interact_with_block.text_2": "\"Bulk Blasting Air Current spreads fire\" is off by default in config to prevent new players from burning their properties accidentally",
  "create_dragons_plus.ponder.bulk_coloring.header": "Nagyüzemi festés",
  "create_dragons_plus.ponder.bulk_coloring.text_1": "Ha a levegő folyékon festéken halad át, akkor létrejön a nagyözemi festés",
  "create_dragons_plus.ponder.bulk_coloring.text_2": "Ahogy a nagyüzemi olvasztás és a nagyüzemi füstölés, a nagyüzemi festés automatikusan kompatibilis bizonyos barkács receptekkel, amelyek festékeket használnak",
  "create_dragons_plus.ponder.bulk_coloring.text_3": "A festékes levegő folyam befolyásolhatja az entitásokat is, megváltoztatva azok színét.",
  "create_dragons_plus.ponder.bulk_coloring.text_4": "A hordott páncél is színezve lesz.",
  "create_dragons_plus.ponder.bulk_enchanting.header": "Bulk Enchanting",
  "create_dragons_plus.ponder.bulk_enchanting.text_1": "Air Flows passing through Golden Aercloud create a Bulk Enchanting setup",
  "create_dragons_plus.ponder.bulk_enchanting.text_2": "Bulk Enchanting processes Aether Enchanter recipes with fan processing",
  "create_dragons_plus.ponder.bulk_enchanting.text_3": "Some recipes repair equipment, so the input and output may be the same item type",
  "create_dragons_plus.ponder.bulk_enchanting.text_4": "The same airflow can incubate Moa Eggs as item processing",
  "create_dragons_plus.ponder.bulk_ending.header": "Nagyüzemi endezés",
  "create_dragons_plus.ponder.bulk_ending.text_1": "Ha a levegő sárkányfejön vagy sárkányleheleten halad át, akkor létrejön a nagyüzemi endezés",
  "create_dragons_plus.ponder.bulk_freezing.header": "Nagyüzemi fagyasztás",
  "create_dragons_plus.ponder.bulk_freezing.text_1": "Ha a levegő porhavon halad át, akkor létrejön a nagyüzemi fagyasztás",
  "create_dragons_plus.ponder.bulk_sanding.header": "Nagyüzemi csiszolás",
  "create_dragons_plus.ponder.bulk_sanding.text_1": "Air Flows passing through Bulk Sanding Catalysts (Example: Quicksand) create a Sanding Setup",
  "create_dragons_plus.ponder.bulk_sanding.text_2": "Ahogy a nagyüzemi olvasztás és a nagyüzemi füstölés, a nagyüzemi csiszolás automatikusan kompatibilis csiszolópapír receptekkel",
  "create_dragons_plus.ponder.dragon_breath_fluid.header": "Dragon's Breath Fluid",
  "create_dragons_plus.ponder.dragon_breath_fluid.text_1": "Dragon's Breath supports Cauldron behaviour",
  "create_dragons_plus.ponder.dragon_breath_fluid.text_2": "When flowing Dragon's Breath meets lava, it forms End Stone",
  "create_dragons_plus.ponder.dye_fluids.header": "Liquid Dye",
  "create_dragons_plus.ponder.dye_fluids.text_1": "Mixing dye with water creates Liquid Dye",
  "create_dragons_plus.ponder.dye_fluids.text_2": "Heated mixing can recover the dye item from the fluid",
  "create_dragons_plus.ponder.dye_fluids.text_3": "Items and living entities touching Liquid Dye are colored",
  "create_dragons_plus.ponder.dye_fluids.text_4": "When Liquid Dye meets lava, it forms matching concrete",
